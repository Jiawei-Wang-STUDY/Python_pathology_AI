from pathlib import Path

# pathlib.Path 的 / 运算符会根据操作系统自动选择路径分隔符：
#   Windows → "notebook_data\\1-1"
#   macOS / Linux → "notebook_data/1-1"
# 因此同一份代码在三个平台下都能正确运行。

PROJECT_ROOT = Path.cwd().resolve()
DATA_DIR = (PROJECT_ROOT.parent / "notebook_data").resolve()

print("PROJECT_ROOT:", PROJECT_ROOT)
print("DATA_DIR:    ", DATA_DIR)
